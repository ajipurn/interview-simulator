# Semua provider default "mock" — game jalan penuh offline tanpa API key.

PORT=4001

# Guardrail budget (default aktif — provider asli dibayar per panggilan/menit)
# MAX_ATTEMPTS=2              # jatah interview seumur hidup per IP
# MAX_SESSIONS_PER_DAY=6      # pembuatan session (rubric LLM) per IP per hari
# INTERVIEW_MAX_MS=720000     # cap durasi interview 12 menit
# IDLE_MAX_MS=180000          # mic nyala tanpa jawaban 3 menit → sesi ditutup

# STT_PROVIDER=deepgram              # mock | deepgram
# DEEPGRAM_API_KEY=

# LLM_PROVIDER=azure-openai          # mock | anthropic | openai | azure-openai | gemini
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_ENDPOINT=             # potong sampai .com saja
# AZURE_OPENAI_DEPLOYMENT=

# TTS_PROVIDER=gcloud                # mock | azure | elevenlabs | edge | gemini | gcloud
# GOOGLE_APPLICATION_CREDENTIALS=    # path service-account JSON
# GOOGLE_TTS_VOICE=Aoede
# GOOGLE_TTS_MODEL=

# Frontend (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:4001
NEXT_PUBLIC_WS_URL=ws://localhost:4001
